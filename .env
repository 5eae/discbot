# Copy this file to ".env" and fill in the values below.

# Your bot's token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Your server (guild) ID — right-click your server icon with Developer Mode on
GUILD_ID=

# Channel ID where pending vouches get sent for mod approval
MOD_CHANNEL_ID=

# Channel ID where approved vouches get publicly posted
VOUCH_CHANNEL_ID=

# Role ID that's allowed to approve/deny vouches (in addition to anyone with Manage Server permission)
MOD_ROLE_ID=
